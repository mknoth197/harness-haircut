    "test": "npm run build && node --test \"test/**/*.test.mjs\"",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mknoth197/harness-haircut.git"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "copilot",
    "codex",
    "gemini",
    "configuration",
    "cli"
  ]
}
