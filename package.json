{
  "name": "harness-haircut",
  "version": "0.0.1",
  "description": "Audit and consolidate redundant AI-provider configuration files into a single canonical source of truth.",
  "type": "module",
  "bin": {
    "harness-haircut": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
